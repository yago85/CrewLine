# Copy this file to .env and fill in your keys
# cp .env.example .env

# =============================================================
# PROVIDER KEYS
# Set the key for your chosen provider. You only need ONE.
# CrewAI uses LiteLLM which auto-routes by "provider/model" prefix.
# =============================================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_key_here

# OpenAI
# OPENAI_API_KEY=your_key_here

# Groq (fast, free tier available)
# GROQ_API_KEY=your_key_here

# OpenRouter (many models, free tier available)
# OPENROUTER_API_KEY=your_key_here

# Ollama (local models, free — requires `ollama serve`)
# IMPORTANT: use 127.0.0.1, NOT localhost — on macOS `localhost` resolves
# to IPv6 ::1 first, but Ollama listens only on IPv4 127.0.0.1 → 503.
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# =============================================================
# MODEL RESOLUTION (priority: per-agent > tier > default)
#
# 1. Per-agent:  MODEL_ARCHITECT=...  overrides only the architect
# 2. Tier:       MODEL_SMART=...      overrides all "smart" agents
# 3. Default:    DEFAULT_LLM=...      fallback for everything
#
# Change provider here — agents.yaml stays untouched.
# =============================================================

# --- Tiers ---
# smart = architect, senior_developer (complex tasks)
# lite  = code_reviewer, qa_engineer, technical_writer, devops_engineer
MODEL_SMART=anthropic/claude-sonnet-4-6
MODEL_LITE=anthropic/claude-haiku-4-5

# --- Fallback ---
DEFAULT_LLM=anthropic/claude-sonnet-4-6

# --- Per-agent overrides (optional) ---
# Uncomment to give a specific agent its own model.
# Variable name = MODEL_ + agent key in UPPER_CASE.
# MODEL_ARCHITECT=anthropic/claude-sonnet-4-6
# MODEL_SENIOR_DEVELOPER=anthropic/claude-sonnet-4-6
# MODEL_CODE_REVIEWER=anthropic/claude-haiku-4-5
# MODEL_QA_ENGINEER=anthropic/claude-haiku-4-5
# MODEL_TECHNICAL_WRITER=anthropic/claude-haiku-4-5
# MODEL_DEVOPS_ENGINEER=anthropic/claude-haiku-4-5

# =============================================================
# PROVIDER PRESETS — uncomment the block for your provider
# =============================================================

# --- Anthropic ---
# MODEL_SMART=anthropic/claude-sonnet-4-6
# MODEL_LITE=anthropic/claude-haiku-4-5

# --- OpenAI ---
# MODEL_SMART=openai/gpt-4o
# MODEL_LITE=openai/gpt-4o-mini

# --- Groq (free) ---
# MODEL_SMART=groq/llama-3.3-70b-versatile
# MODEL_LITE=groq/llama-3.1-8b-instant

# --- OpenRouter (free) ---
# MODEL_SMART=openrouter/nvidia/nemotron-3-super-120b-a12b:free
# MODEL_LITE=openrouter/nvidia/nemotron-nano-9b-v2:free

# --- Ollama (local, free) ---
# MODEL_SMART=ollama/qwen3-coder:30b
# MODEL_LITE=ollama/llama3.2:3b
# OLLAMA_BASE_URL=http://127.0.0.1:11434  # 127.0.0.1 required, not localhost (IPv6 issue)

# =============================================================
# MEMORY (used when --memory is enabled)
# Provider-agnostic: works with Anthropic, Google, Cohere, Ollama — no OpenAI required.
#
# MEMORY_LLM   — LLM for memory analysis/summarization (defaults to MODEL_SMART)
# MEMORY_PROVIDER — force specific embedder provider (auto-detected by available keys otherwise)
# Auto-detection order: OpenAI → Google → Cohere → Ollama
# =============================================================

# MEMORY_LLM=anthropic/claude-haiku-4-5   # override analysis LLM (default: MODEL_SMART)

# MEMORY_PROVIDER=openai        # requires OPENAI_API_KEY
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MEMORY_PROVIDER=google        # requires GOOGLE_API_KEY
# GOOGLE_API_KEY=your_key_here
# GOOGLE_EMBEDDING_MODEL=models/text-embedding-004

# MEMORY_PROVIDER=cohere        # requires COHERE_API_KEY
# COHERE_API_KEY=your_key_here
# COHERE_EMBEDDING_MODEL=embed-english-v3.0

# MEMORY_PROVIDER=ollama        # local, free — requires `ollama pull nomic-embed-text`
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://127.0.0.1:11434  # 127.0.0.1 required, not localhost (macOS IPv6 issue)
